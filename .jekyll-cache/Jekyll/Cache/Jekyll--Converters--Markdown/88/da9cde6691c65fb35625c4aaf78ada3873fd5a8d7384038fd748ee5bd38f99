    <div class="language-java highlighter-rouge"><div class="highlight"><pre class="highlight"><code>	<span class="n">主函数先输出</span>
		<span class="nc">System</span><span class="o">.</span><span class="na">out</span><span class="o">.</span><span class="na">println</span><span class="o">(</span><span class="s">"Binary tree:"</span><span class="o">);</span>
		<span class="n">printInOrder</span><span class="o">(</span><span class="n">head</span><span class="o">,</span> <span class="mi">0</span><span class="o">,</span> <span class="s">"H"</span><span class="o">,</span> <span class="mi">17</span><span class="o">);</span>	<span class="c1">// 规定len始终为17，头结点为 HxxxH</span>
